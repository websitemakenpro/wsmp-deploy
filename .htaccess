Options -Indexes
ServerSignature Off

# ── Security headers ──────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# ── Rewrite engine ────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1) Domain check API
    RewriteRule ^api/domain-check$ /domain-check-api/index.php [L,QSA]
    RewriteRule ^api/domain-check/$ /domain-check-api/index.php [L,QSA]

    # 2) Order API
    RewriteRule ^api/order$ /api-order/index.php [L,QSA]
    RewriteRule ^api/order/$ /api-order/index.php [L,QSA]
    RewriteRule ^api-order/$ /api-order/index.php [L,QSA]

    # 3) Don't rewrite real files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4) SPA fallback — serve index.html for all other routes
    #    (handles /domain-check, /blog, /locaties, etc.)
    RewriteRule ^ /index.html [L]
</IfModule>

# ── Gzip compression ──────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Browser caching ───────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 1 hour"
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/svg+xml             "access plus 1 month"
    ExpiresByType image/webp                "access plus 1 month"
</IfModule>
